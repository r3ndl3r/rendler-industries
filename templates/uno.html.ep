<%# /templates/uno.html.ep %>

% layout 'default';
% title '🃏 UNO Online';

% content_for 'head' => begin
    <link rel="stylesheet" href="/css/uno.css">
    <script src="/js/uno.js"></script>
% end

<div class="app-container">
    <div id="uno-app" class="component-loading">
        <div class="loading-scan-line"></div>
        <span class="loading-icon-pulse">🃏</span>
        <p class="loading-label">Initializing UNO Deck...</p>
    </div>
</div>
