<%# /templates/layouts/default.html.ep %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= title %> | Rendler Industries®</title>

    <link rel="icon" href="/files/serve/54">

    <link rel="stylesheet" href="/css/default.css?<%= time %>">
    <link rel="stylesheet" href="/css/emoji-picker.css?<%= time %>">
    <link rel="stylesheet" href="/css/menu/menubar.css?<%= time %>">

    <script src="/js/jquery.js?<%= time %>"></script>
    <script src="/js/toast.js?<%= time %>"></script>
    <script src="/js/default.js?<%= time %>"></script>
    <script src="/js/emoji-picker.js?<%= time %>"></script>
    <script src="/js/menu/menubar.js?<%= time %>"></script>
    
<%= content_for 'head' %>
</head>

<body class="bg-gray-900 text-gray-200 font-sans">
    <%= include 'menu/menubar' %>
    <%= content %>
    <%# --- GLOBAL GENERIC CONFIRMATION MODAL --- %>
    <div id="globalConfirmActionModal" class="delete-modal-overlay" style="display: none;">
        <div class="delete-modal-content">
            <div class="delete-modal-header">
                <h3><span id="globalConfirmModalIcon"><%= icon('delete') %></span> <span id="globalConfirmModalTitle">Confirm Action</span></h3>
                <span class="delete-modal-close" onclick="closeConfirmModal()">&times;</span>
            </div>
            <div class="delete-modal-body">
                <p id="globalConfirmModalText"></p>
            </div>
            <div class="delete-modal-actions" style="justify-content: center !important;">
                <button id="globalConfirmModalBtn" class="btn-danger-confirm">Confirm</button>
                <button class="btn-secondary" onclick="closeConfirmModal()">Cancel</button>
            </div>
        </div>
    </div>
</body>
</html>