<%# /templates/settings.html.ep %>

% layout 'default';
% title icon('settings') . ' Settings';

% content_for 'head' => begin
  <link rel="stylesheet" href="/css/settings.css?<%= time %>">
  <script src="/js/settings.js?<%= time %>"></script>
% end

<div class="settings-container">
  <div class="header-bar">
    <h1><%= icon('settings') %> <span>Settings</span></h1>
  </div>

  <div class="settings-layout">
    <nav class="settings-nav">
      <button class="settings-tab active" data-tab="notifications">
        <span class="tab-icon"><%= icon('reminders') %></span>
        <span class="tab-label">Notifications</span>
      </button>
      <button class="settings-tab" data-tab="email">
        <span class="tab-icon"><%= icon('register') %></span>
        <span class="tab-label">Email</span>
      </button>
      <button class="settings-tab" data-tab="integrations">
        <span class="tab-icon"><%= icon('link') %></span>
        <span class="tab-label">Integrations</span>
      </button>
      <button class="settings-tab" data-tab="application">
        <span class="tab-icon"><%= icon('settings') %></span>
        <span class="tab-label">Application</span>
      </button>
    </nav>

    <div class="settings-panels">

      <%# Notifications %>
      <div class="settings-panel active" id="panel-notifications">

        <div class="settings-card" data-card="pushover">
          <div class="settings-card-header" role="button" tabindex="0" aria-expanded="false">
            <div class="card-header-meta">
              <h3 class="settings-card-title">Pushover</h3>
              <p class="settings-card-desc">Push notifications to your devices via the Pushover service.</p>
            </div>
            <div class="card-header-right">
              <span class="settings-badge <%= $settings->{pushover}{token} ? 'badge-active' : 'badge-inactive' %>">
                <%= $settings->{pushover}{token} ? 'Configured' : 'Not Set' %>
              </span>
              <span class="card-chevron"></span>
            </div>
          </div>
          <div class="settings-card-body">
            <div class="settings-card-body-inner">
              <form method="POST" action="/settings/update">
                <input type="hidden" name="section" value="pushover">
                <div class="settings-fields">
                  <div class="form-group">
                    <label>API Token</label>
                    <div class="input-wrapper">
                      <input type="password" name="pushover_token" class="form-input"
                        value="<%= $settings->{pushover}{token} // '' %>" autocomplete="off">
                      <button type="button" class="btn-toggle" data-toggle-visibility>Show</button>
                    </div>
                  </div>
                  <div class="form-group">
                    <label>User Key</label>
                    <div class="input-wrapper">
                      <input type="password" name="pushover_user" class="form-input"
                        value="<%= $settings->{pushover}{user} // '' %>" autocomplete="off">
                      <button type="button" class="btn-toggle" data-toggle-visibility>Show</button>
                    </div>
                  </div>
                </div>
                <div class="form-actions">
                  <button type="submit" class="btn-primary btn-small">Save Pushover</button>
                </div>
              </form>
            </div>
          </div>
        </div>

        <div class="settings-card" data-card="gotify">
          <div class="settings-card-header" role="button" tabindex="0" aria-expanded="false">
            <div class="card-header-meta">
              <h3 class="settings-card-title">Gotify</h3>
              <p class="settings-card-desc">Self-hosted push notifications via your Gotify server.</p>
            </div>
            <div class="card-header-right">
              <span class="settings-badge <%= $settings->{gotify}{token} ? 'badge-active' : 'badge-inactive' %>">
                <%= $settings->{gotify}{token} ? 'Configured' : 'Not Set' %>
              </span>
              <span class="card-chevron"></span>
            </div>
          </div>
          <div class="settings-card-body">
            <div class="settings-card-body-inner">
              <form method="POST" action="/settings/update">
                <input type="hidden" name="section" value="gotify">
                <div class="settings-fields">
                  <div class="form-group full-width">
                    <label>Application Token</label>
                    <div class="input-wrapper">
                      <input type="password" name="gotify_token" class="form-input"
                        value="<%= $settings->{gotify}{token} // '' %>" autocomplete="off">
                      <button type="button" class="btn-toggle" data-toggle-visibility>Show</button>
                    </div>
                  </div>
                </div>
                <div class="form-actions">
                  <button type="submit" class="btn-primary btn-small">Save Gotify</button>
                </div>
              </form>
            </div>
          </div>
        </div>

      </div>

      <%# Email %>
      <div class="settings-panel" id="panel-email">

        <div class="settings-card" data-card="gmail">
          <div class="settings-card-header" role="button" tabindex="0" aria-expanded="false">
            <div class="card-header-meta">
              <h3 class="settings-card-title">Gmail SMTP</h3>
              <p class="settings-card-desc">Outbound email for notifications and calendar reminders.</p>
            </div>
            <div class="card-header-right">
              <span class="settings-badge <%= $email_settings->{gmail_email} ? 'badge-active' : 'badge-inactive' %>">
                <%= $email_settings->{gmail_email} ? 'Configured' : 'Not Set' %>
              </span>
              <span class="card-chevron"></span>
            </div>
          </div>
          <div class="settings-card-body">
            <div class="settings-card-body-inner">
              <form method="POST" action="/settings/update">
                <input type="hidden" name="section" value="email">
                <div class="form-info">
                  Use a Gmail App Password — not your account password.
                  <a href="https://myaccount.google.com/apppasswords" target="_blank" rel="noopener">Generate one here ↗</a>
                </div>
                <div class="settings-fields">
                  <div class="form-group">
                    <label>Gmail Address</label>
                    <div class="input-wrapper">
                      <input type="email" name="gmail_email" class="form-input"
                        value="<%= $email_settings->{gmail_email} // '' %>" placeholder="you@gmail.com">
                    </div>
                  </div>
                  <div class="form-group">
                    <label>App Password</label>
                    <div class="input-wrapper">
                      <input type="password" name="gmail_app_password" class="form-input"
                        value="<%= $email_settings->{gmail_app_password} // '' %>" autocomplete="off">
                      <button type="button" class="btn-toggle" data-toggle-visibility>Show</button>
                    </div>
                  </div>
                  <div class="form-group full-width">
                    <label>From Name <span class="label-optional">(optional)</span></label>
                    <div class="input-wrapper">
                      <input type="text" name="gmail_from_name" class="form-input"
                        value="<%= $email_settings->{from_name} // '' %>" placeholder="e.g. Home Dashboard">
                    </div>
                  </div>
                </div>
                <div class="form-actions">
                  <button type="submit" class="btn-primary btn-small">Save Email Settings</button>
                </div>
              </form>
            </div>
          </div>
        </div>

      </div>

      <%# Integrations %>
      <div class="settings-panel" id="panel-integrations">

        <div class="settings-card" data-card="unsplash">
          <div class="settings-card-header" role="button" tabindex="0" aria-expanded="false">
            <div class="card-header-meta">
              <h3 class="settings-card-title">Unsplash</h3>
              <p class="settings-card-desc">High-quality images for the Imposter game. Falls back to Picsum if unset.</p>
            </div>
            <div class="card-header-right">
              <span class="settings-badge <%= $settings->{unsplash_key} ? 'badge-active' : 'badge-inactive' %>">
                <%= $settings->{unsplash_key} ? 'Configured' : 'Using Picsum' %>
              </span>
              <span class="card-chevron"></span>
            </div>
          </div>
          <div class="settings-card-body">
            <div class="settings-card-body-inner">
              <form method="POST" action="/settings/update">
                <input type="hidden" name="section" value="unsplash">
                <div class="settings-fields">
                  <div class="form-group full-width">
                    <label>Access Key</label>
                    <div class="input-wrapper">
                      <input type="password" name="unsplash_key" class="form-input"
                        value="<%= $settings->{unsplash_key} // '' %>" autocomplete="off">
                      <button type="button" class="btn-toggle" data-toggle-visibility>Show</button>
                    </div>
                  </div>
                </div>
                <div class="form-actions">
                  <button type="submit" class="btn-primary btn-small">Save Unsplash</button>
                </div>
              </form>
            </div>
          </div>
        </div>

        <div class="settings-card" data-card="gemini">
            <div class="settings-card-header" role="button" tabindex="0" aria-expanded="false">
                <div class="card-header-meta">
                <h3 class="settings-card-title">Google Gemini</h3>
                <p class="settings-card-desc">Gemini API key and model configuration.</p>
                </div>
                <div class="card-header-right">
                <span class="settings-badge <%= $gemini_key ? 'badge-active' : 'badge-inactive' %>">
                    <%= $gemini_key ? 'Configured' : 'Not Set' %>
                </span>
                <span class="card-chevron"></span>
                </div>
            </div>
            <div class="settings-card-body">
                <div class="settings-card-body-inner">
                <form method="POST" action="/settings/update">
                    <input type="hidden" name="section" value="gemini">
                    <div class="settings-fields">
                        <div class="form-group full-width">
                            <label>API Key</label>
                            <div class="input-wrapper">
                            <input type="password" name="gemini_key" class="form-input"
                                value="<%= $gemini_key // '' %>" autocomplete="off">
                            <button type="button" class="btn-toggle" data-toggle-visibility>Show</button>
                            </div>
                        </div>
                        <div class="form-group full-width">
                            <label>Active Model</label>
                            <div class="input-wrapper">
                                <select name="gemini_active_model" class="form-input gemini-select">
                                    % for my $model (@$gemini_models) {
                                        <option value="<%= $model %>" <%= $model eq $gemini_active ? 'selected' : '' %>><%= $model %></option>
                                    % }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn-primary btn-small">Save Gemini Settings</button>
                    </div>
                </form>

                <hr class="settings-separator">

                <div class="settings-fields">
                    <div class="form-group full-width">
                        <label>Available Models</label>
                        <div class="model-list-container">
                            % for my $model (@$gemini_models) {
                                <div class="pill-badge">
                                    <span class="model-name-text"><%= $model %></span>
                                    <form onsubmit="confirmDeleteModel('<%= $model %>'); return false;" class="form-inline">
                                        <button type="submit" class="btn-remove-model" title="Remove Model">&times;</button>
                                    </form>
                                </div>
                            % }
                        </div>
                    </div>
                    <form id="addModelForm" class="w-100">
                        <input type="hidden" name="section" value="gemini_models">
                        <input type="hidden" name="action" value="add">
                        <div class="form-group mt-15">
                            <label>Add New Model Name</label>
                            <div class="d-flex gap-10">
                                <input type="text" name="new_model" class="form-input" placeholder="e.g. gemini-3.1-pro-preview">
                                <button type="submit" class="btn-primary btn-small nowrap">Add Model</button>
                            </div>
                        </div>
                    </form>
                </div>
                </div>
            </div>
        </div>

        <div class="settings-card" data-card="google_tts">
            <div class="settings-card-header" role="button" tabindex="0" aria-expanded="false">
                <div class="card-header-meta">
                    <h3 class="settings-card-title">Google Text-to-Speech</h3>
                    <p class="settings-card-desc">Google Cloud TTS API key for voice synthesis.</p>
                </div>
                <div class="card-header-right">
                    <span class="settings-badge <%= $google_tts_key ? 'badge-active' : 'badge-inactive' %>">
                        <%= $google_tts_key ? 'Configured' : 'Not Set' %>
                    </span>
                    <span class="card-chevron"></span>
                </div>
            </div>
            <div class="settings-card-body">
                <div class="settings-card-body-inner">
                    <form method="POST" action="/settings/update">
                        <input type="hidden" name="section" value="google_tts">
                        <div class="settings-fields">
                            <div class="form-group full-width">
                                <label>API Key</label>
                                <div class="input-wrapper">
                                    <input type="password" name="google_tts_key" class="form-input"
                                        value="<%= $google_tts_key // '' %>" autocomplete="off">
                                    <button type="button" class="btn-toggle" data-toggle-visibility>Show</button>
                                </div>
                            </div>
                        </div>
                        <div class="form-actions">
                            <button type="submit" class="btn-primary btn-small">Save TTS Settings</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

      </div>

      <%# Application %>
      <div class="settings-panel" id="panel-application">

        <div class="settings-card" data-card="timers">
          <div class="settings-card-header" role="button" tabindex="0" aria-expanded="false">
            <div class="card-header-meta">
              <h3 class="settings-card-title">Timer Reset</h3>
              <p class="settings-card-desc">Hour of day when daily timers reset automatically (Australia/Melbourne timezone).</p>
            </div>
            <div class="card-header-right">
              <span class="settings-badge badge-active">Daily @ <%= $timer_reset_hour %>:00</span>
              <span class="card-chevron"></span>
            </div>
          </div>
          <div class="settings-card-body">
            <div class="settings-card-body-inner">
              <form method="POST" action="/settings/update">
                <input type="hidden" name="section" value="timers">
                <div class="settings-fields">
                  <div class="form-group full-width">
                    <label>Reset Hour <span class="label-optional">(0 = midnight, 15 = 3 PM)</span></label>
                    <div class="input-wrapper">
                      <input type="number" name="timer_reset_hour" class="form-input no-pad-right"
                        value="<%= $timer_reset_hour %>" min="0" max="23">
                    </div>
                  </div>
                </div>
                <div class="form-actions">
                  <button type="submit" class="btn-primary btn-small">Save Timer</button>
                </div>
              </form>
            </div>
          </div>
        </div>

        <div class="settings-card" data-card="app-secret">
          <div class="settings-card-header" role="button" tabindex="0" aria-expanded="false">
            <div class="card-header-meta">
              <h3 class="settings-card-title">App Secret</h3>
              <p class="settings-card-desc">Mojolicious session signing key. Used to verify session cookies.</p>
            </div>
            <div class="card-header-right">
              <span class="card-chevron"></span>
            </div>
          </div>
          <div class="settings-card-body">
            <div class="settings-card-body-inner">
              <form method="POST" action="/settings/update">
                <input type="hidden" name="section" value="app_secret">
                <div class="form-warning">
                  <%= icon('warning') %> Changing this invalidates all active sessions. An app restart is required for the new key to take effect.
                </div>
                <div class="settings-fields">
                  <div class="form-group full-width">
                    <label>Secret Key <span class="label-optional">(min. 32 characters)</span></label>
                    <div class="input-wrapper">
                      <input type="password" name="app_secret" class="form-input"
                        value="<%= $settings->{app_secret} // '' %>" autocomplete="off">
                      <button type="button" class="btn-toggle" data-toggle-visibility>Show</button>
                    </div>
                  </div>
                </div>
                <div class="form-actions">
                  <button type="submit" class="btn-danger btn-small">Update Secret</button>
                </div>
              </form>
            </div>
          </div>
        </div>

      </div>

    </div>
  </div>
</div>
